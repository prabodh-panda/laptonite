#!/usr/bin/env bash
#
# set -e tells bash: exit immediately if any command returns a
# non-zero status (i.e., “fails”).
# It does not always trigger in every context.
# * If the `if` condition fails then it won't exit.
# * might_fail || echo "handled"    # won’t exit because `||` handles it
set -eE
trap 'echo "Error on line $LINENO (exit code $?)" >&2' ERR

if [ "$(uname -m)" != "arm64" ]; then
  echo "You are using Intel chips and this laptonite script doesn't support Intel chips."
  echo "This laptonite script is meant only for M series Silicon chips laptops."
  exit 1
fi

if xcrun --show-sdk-path >/dev/null 2>&1; then
  echo "" # no ops
else
  echo "Please run: xcode-select --install"
  exit 1
fi

# Update DEVBOXD based on where setup is being run from
./bin/create-devbox-env

# Load .devbox.env (source local file since $HOME symlink may not exist yet)
[ -f "./zsh/.devbox" ] && source "./zsh/.devbox"
LAPTONITED="$DEVBOXD/laptonite"

# TEMPORARY: Remove the old "laptop" directory that was renamed to "laptonite".
# This block can be removed once all machines have run setup at least once.
if [ -d "$DEVBOXD/laptop" ]; then
  echo "Removing old 'laptop' directory ..."
  rm -rf "$DEVBOXD/laptop"
fi

# Remove destination (file/symlink/dir) and recreate symlink
# If destination is a real file (not a symlink), back it up first
echo_header() {
  echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
  echo "$1"
}

echo_header_done() {
  echo "Done!!!"
  echo ""
}

link_force() {
  src="$1"
  dst="$2"

  if [ -z "$src" ] || [ -z "$dst" ]; then
    echo "Usage: link_force <src> <dst>" >&2
    return 1
  fi

  if [ ! -e "$src" ] && [ ! -L "$src" ]; then
    echo "Missing source: $src" >&2
    return 1
  fi

  # Backup dst if it's a real file (not a symlink)
  if [ -e "$dst" ] && [ ! -L "$dst" ]; then
    backup="${dst}-bkp-$(date +%Y%m%d%H%M%S)"
    echo "Backing up $dst to $backup"
    mv -- "$dst" "$backup"
  else
    rm -rf -- "$dst"
  fi

  ln -s -- "$src" "$dst"
}

echo_header "Setting up soft links for zshrc, gemrc, gitconfig, gitignore, irbrc, psqlrc & wezterm"
link_force "$LAPTONITED/zsh/zshrc"          "$HOME/.zshrc"
link_force "$LAPTONITED/zsh/.devbox"         "$HOME/.devbox"

link_force "$LAPTONITED/symlinks/.gemrc"    "$HOME/.gemrc"
link_force "$LAPTONITED/symlinks/.gitconfig" "$HOME/.gitconfig"
link_force "$LAPTONITED/symlinks/.gitignore" "$HOME/.gitignore"
link_force "$LAPTONITED/symlinks/.irbrc"    "$HOME/.irbrc"
link_force "$LAPTONITED/symlinks/.psqlrc"   "$HOME/.psqlrc"

mkdir -p "$HOME/.config"
link_force "$LAPTONITED/symlinks/wezterm"   "$HOME/.config/wezterm"
link_force "$LAPTONITED/symlinks/mise"      "$HOME/.config/mise"

mkdir -p "$HOME/.claude"
mkdir -p "$LAPTONITED/symlinks/skills"
link_force "$LAPTONITED/symlinks/claude/settings.json"    "$HOME/.claude/settings.json"
link_force "$LAPTONITED/symlinks/skills"    "$HOME/.claude/skills"

mkdir -p "$HOME/.pi/agent"
mkdir -p "$HOME/.pi/agent/extensions"
mkdir -p "$LAPTONITED/symlinks/pi/agent/extensions"
link_force "$LAPTONITED/symlinks/pi/agent/settings.json"    "$HOME/.pi/agent/settings.json"
link_force "$LAPTONITED/symlinks/pi/agent/extensions/wezterm-tab-color.ts"    "$HOME/.pi/agent/extensions/wezterm-tab-color.ts"

mkdir -p "$HOME/.config/cmux"
link_force "$LAPTONITED/symlinks/cmux/cmux.json"    "$HOME/.config/cmux/cmux.json"

echo_header_done

echo_header "Setting up homebrew"
# Install Homebrew if not already installed
if ! command -v brew &> /dev/null; then
  echo "Homebrew not found. Installing..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

  # Add brew to PATH for the rest of this script
  if [ -f /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [ -f /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
fi
echo_header_done

abrew() {
  arch -arm64 brew "$@"
}

brew_install() {
  abrew install --verbose "$1"
}

echo_header "Upgrade homebrew"
abrew update --verbose
echo_header_done

echo_header "Upgrade any already-installed formulae"
abrew upgrade --verbose
echo_header_done

echo_header "Installing various applications"
brew_install zoxide    # for jumping around
brew_install fzf
brew_install eza       # this is replacement for ls
brew_install git
brew_install git-delta # Used in pager
brew_install httpd     # ab(apache bench) comes with this
brew_install k6        # see bin/simulate-traffic-k6
brew_install gh        # GitHub CLI
brew_install jq
brew_install zsh-autosuggestions
brew_install zsh-syntax-highlighting
brew_install mise
brew_install curl # curl that comes with Mac is highly outdated
brew_install ripgrep
brew_install aicommits
brew_install libyaml #mise needs it
brew_install postgresql@18
brew_install redis
brew_install font-hack-nerd-font
brew_install jnsahaj/lumen/lumen

brew_install opensearch # elastic search alternative
#arch -arm64 brew install openjdk@17
#export JAVA_HOME="/opt/homebrew/opt/openjdk@17"
#arch -arm64 brew tap elastic/tap
#arch -arm64 brew install elastic/tap/elasticsearch-full

npm install -g opencommit
oco config set OCO_GITPUSH=false

# try install; if it fails due to an existing app, adopt; if adopt fails, force.
cask_install() {
  local cask="$1"
  if abrew list --cask "$cask" >/dev/null 2>&1; then
    # Verify the app actually exists in /Applications (brew may think it's
    # installed even if the .app was manually removed)
    local app_missing=false
    local app_name
    app_name=$(abrew info --cask "$cask" 2>/dev/null | grep '\.app (App)' | head -1 | sed 's/.*\///' | sed 's/ (App)//')
    if [ -n "$app_name" ] && [ ! -d "/Applications/$app_name" ]; then
      app_missing=true
    fi

    if [ "$app_missing" = false ]; then
      echo "Already installed: $cask"
      return 0
    fi

    echo "$cask is registered in brew but app is missing. Reinstalling..."
    abrew reinstall --verbose --cask "$cask" && return 0
  fi

  abrew install --verbose --cask "$cask" && return 0

  echo "Install failed for $cask; trying --adopt..."
  abrew install --verbose --cask "$cask" --adopt && return 0

  echo "Adopt failed for $cask; trying --force..."
  abrew install --verbose --cask "$cask" --force
}

cask_install raycast
cask_install whatsapp
cask_install visual-studio-code
cask_install wezterm
cask_install meetingbar
cask_install 1password
cask_install dbeaver-community # client for database
cask_install slack
echo_header_done

echo_header "Installing Claude Code"
/bin/bash -c "$(curl -fsSL https://claude.ai/install.sh)"
echo_header_done

echo_header "Setting up gitconfig-local"
ruby ./bin/setup-gitconfig-local.rb
echo_header_done

echo_header "Setting up raycast"
echo ""
echo "Would you like to reset Raycast settings and apply"
echo "the ones provided by Neeto?"
echo "If you have not customized your Raycast yet then you should hit \"c\"."
read -p "Hit Enter to keep current settings. Press c to change." answer
if [[ "$answer" =~ ^[Cc](hange)?$ ]]; then
  ./bin/fetch-latest-raycast-export

  echo ""
  echo "To import Raycast settings:"
  echo "  1. Open Raycast"
  echo "  2. Press Cmd and comma(,) to open Settings"
  echo "  3. Click on the 'Advanced' tab"
  echo "  4. Scroll to 'Import & Export'"
  echo "  5. Click 'Import'"
  echo "  6. Choose 'latest-raycast-export.rayconfig' from your Downloads folder"
  echo "  7. Enter password welcome1234"
  echo ""
  echo "Waiting for you to finish the steps above."
  while true; do
    read -p "Press D when are done: " key
    [[ "$key" =~ ^[Dd]$ ]] && break
  done
fi
echo_header_done

echo ""
echo_header "Customizing macos configuration."
echo "Would you like to change your macos configurations?"
read -p "Hit Enter to skip. Press c to change your macos configuration. " answer
if [[ "$answer" =~ ^[Cc](hange)?$ ]]; then
  echo "You will be asked to provide your laptop password."
  ./bin/customize-macos
  echo_header_done
fi

echo ""
echo_header "Setting up GitHub SSH keys"
echo "Would you like to set up a GitHub SSH key?"
echo "If you already have one configured, then you can skip."
read -p "Hit Enter to skip. Press c to set up your SSH key. " answer
if [[ "$answer" =~ ^[Cc](hange)?$ ]]; then
  ./bin/setup-github-ssh-key

  echo_header "Authenticating with GitHub CLI"
  gh auth login
  echo_header_done
fi
echo_header_done


# Tell mise to trust everything under directory code
export MISE_TRUSTED_CONFIG_PATHS="$HOME/code"

# mise needs it to compile Ruby properly
export RUBY_CONFIGURE_OPTS="--with-libyaml-dir=$(abrew --prefix libyaml)"

echo ""
echo "You are all done."
echo "See README at https://github.com/neerajsingh0101/laptonite to get to know keyboard shortcuts."

DOTFILESD="$DEVBOXD/dotfiles"

# If you want your custom script to be executed as part of the setup
# then setup a directory called "dotfiles" as a sibling to the "laptonite"
# directory. This directory shoudl have a file called "setup". This
# "setup" file should be executable.
#
# See https://github.com/neerajsingh0101/dotfiles/blob/main/setup
# as a real world example.
#
if [ -d "$DOTFILESD" ] && [ -f "$DOTFILESD/setup" ]; then
  "$DOTFILESD/setup"
fi

echo_header "Ensuring ~/.zshenv has mise shims on PATH"
MISE_SHIMS_LINE='export PATH="$HOME/.local/share/mise/shims:$PATH"'
if [ ! -f "$HOME/.zshenv" ] || ! grep -Fqx "$MISE_SHIMS_LINE" "$HOME/.zshenv"; then
  echo "$MISE_SHIMS_LINE" >> "$HOME/.zshenv"
fi
echo_header_done

echo ""
echo "Reloading shell..."
exec "$SHELL" -l
